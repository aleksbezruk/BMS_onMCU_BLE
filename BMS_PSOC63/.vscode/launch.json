        {
            "name": "Debug Qutest (KitProg3_MiniProg4)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "proj_cm4/build/APP_CY8CPROTO-063-BLE/Debug/proj_cm4.elf",
            "servertype": "openocd",
            "searchDir": [
                "${workspaceFolder}",
                "${config:modustoolbox.toolsPath}/../../ModusToolboxProgtools-1.2/openocd/scripts/",
                "bsps/TARGET_APP_CY8CPROTO-063-BLE/config/GeneratedSource"
            ],
            "configFiles": [
                "openocd.tcl"
            ],
            "openOCDPreConfigLaunchCommands": [

            ],
            "overrideLaunchCommands": [
                "set mem inaccessible-by-default off",
                "-enable-pretty-printing",
                "set remotetimeout 25",
                "monitor reset init",
                // Comment this next lines out if you don't want to reload program
                "monitor flash write_image erase {build/app_combined.hex}",
                "monitor reset init",
                "monitor psoc6 reset_halt sysresetreq"
            ],
            // svdFile is optional, it can be very large.
            "svdFile": "../mtb_shared/mtb-pdl-cat1/release-v3.11.0/devices/COMPONENT_CAT1A/svd/psoc6_01.svd",
            "numberOfProcessors": 2,
            "targetProcessor": 1, // Set to 0 for the CM0+, set to 1 for the CM4
            "postStartSessionCommands": [
                // Needed if runToMain is false
                // Following two commands are needed to get gdb and openocd and HW all in sync.
                // Or, execution context (PC, stack, registers, etc.) look like they are from before reset.
                // The stepi, is a pretend instruction that does not actually do a stepi, but MUST be done
                // Its a documented workaround in openocd. Do a 'monitor help' to see more info
                //
                // An alternative command to use is "continue" instead of the following two
                "monitor gdb_sync",
                "stepi"
            ],
            "overrideRestartCommands": [
                "starti"
            ],
            "postRestartSessionCommands": [
            ],
            "breakAfterReset": true,
            "runToEntryPoint": "main",    // Specifies application entry point name where program will halt
            "showDevDebugOutput": "none",
            "preLaunchTask": "Build Qutest",    // Set this to run a task from tasks.json
            "presentation": {
                "hidden": false,
                "group": "CM4"
            }
        },
