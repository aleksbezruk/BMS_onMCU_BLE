{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "call CMake to generate the make files",
            "command": "cmake -DCMAKE_MAKE_PROGRAM=\"make\" -G \"Unix Makefiles\" ..",
            "options": {
                "cwd": "./build"
            },
            "group": "build",
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": ["relative", "./build"]
            }
        },
        {
            "type": "shell",
            "label": "Build Project",
            "command": "cmake --build .",
            "options": {
                "cwd": "./build"
            },
            "group": { 
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "base": "$gcc", 
                "fileLocation": ["relative", "./build"]
            }
        },
        {
            "type": "shell",
            "label": "Clean and Build Project",
            "command": "cmake --build . --clean-first",
            "options": {
                "cwd": "./build"
            },
            "group": "build",
            "problemMatcher": {
                "base": "$gcc", 
                "fileLocation": ["relative", "./build"]
            }
        },
        {
            "type": "shell",
            "label": "Rebuild All",
            "dependsOrder": "sequence",
            "dependsOn": [
                "call CMake to generate the make files",
                "Clean and Build Project"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}